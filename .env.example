# =========================
# Application
# =========================
APP_ENV=production
APP_BASE_URL=https://tmail.kaishop.id.vn
APP_TIMEZONE=Asia/Ho_Chi_Minh
DISPLAY_ERRORS=false
EXPOSE_ERROR_DETAILS=false

# =========================
# Database
# =========================
DB_HOST=127.0.0.1
DB_NAME=kaimail_production
DB_USER=kaimail_user
DB_PASS=change_this_strong_db_password
DB_CHARSET=utf8mb4
DB_TIMEZONE=+07:00

# =========================
# Security Keys
# =========================
WEBHOOK_SECRET=replace_with_64_hex_webhook_secret
API_ACCESS_KEY=replace_with_strong_api_access_key
API_SECRET_KEY=replace_with_64_hex_api_secret
ADMIN_ACCESS_KEY=replace_with_strong_admin_access_key
API_REQUEST_TTL=300
API_REQUIRE_HTTPS=true
API_ALLOWED_IPS=

# =========================
# Session Security
# =========================
SESSION_NAME=kaimail_session
SESSION_LIFETIME=86400
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAMESITE=Strict
SESSION_COOKIE_PATH=/
SESSION_COOKIE_DOMAIN=tmail.kaishop.id.vn
