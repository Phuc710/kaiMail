# =========================
# Application
# =========================
APP_ENV=local
APP_BASE_URL=http://localhost/kaiMail
APP_TIMEZONE=Asia/Ho_Chi_Minh
DISPLAY_ERRORS=false
EXPOSE_ERROR_DETAILS=false

# =========================
# Database
# =========================
DB_HOST=localhost
DB_NAME=kaimail
DB_USER=root
DB_PASS=

# DB_NAME=your_production_db
# DB_USER=your_production_user
# DB_PASS=your_production_password

DB_CHARSET=utf8mb4
DB_TIMEZONE=+07:00

# =========================
# Security Keys
# =========================
WEBHOOK_SECRET=replace_with_64_hex_secret
API_ACCESS_KEY=replace_with_64_hex_access_key
API_SECRET_KEY=replace_with_64_hex_secret_key
ADMIN_ACCESS_KEY=replace_with_long_admin_access_key
API_REQUEST_TTL=300
API_REQUIRE_HTTPS=true
API_ALLOWED_IPS=
API_ALLOW_SESSION_FALLBACK=false
API_REQUIRE_NONCE=true
API_NONCE_TTL=300
API_RATE_LIMIT_PER_MIN=120
API_STRICT_MODE=true
API_TRUST_PROXY_HEADERS=false
ADMIN_REQUIRE_HTTPS=true
ADMIN_ALLOWED_IPS=
ADMIN_RATE_LIMIT_PER_MIN=60
ADMIN_LOGIN_RATE_LIMIT_PER_MIN=15

# =========================
# Session Security
# =========================
SESSION_NAME=kaimail_session
SESSION_LIFETIME=86400
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAMESITE=Strict
SESSION_COOKIE_PATH=/
SESSION_COOKIE_DOMAIN=tmail.kaishop.id.vn
